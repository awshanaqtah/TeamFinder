{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for TeamFinder desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "store:default",
    "global-shortcut:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save"
  ]
}
